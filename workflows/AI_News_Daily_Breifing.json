      "id": "9ee4d56c-da40-4cbf-a548-177c005340e1",
      "name": "Merge"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst seen = new Set();\nconst merged = [];\n\nfor (const item of items) {\n  const title = item.json.title || '';\n  if (title && !seen.has(title)) {\n    seen.add(title);\n    merged.push({\n      title: item.json.title || '',\n      url: item.json.link || item.json.url || '',\n      pubDate: item.json.pubDate || item.json.isoDate || '',\n      summary: item.json.contentSnippet || item.json.content || ''\n    });\n  }\n}\n\nmerged.sort((a, b) => new Date(b.pubDate) - new Date(a.pubDate));\nconst top10 = merged.slice(0, 5);\n\nconst newsText = top10.map((n, i) => \n  `${i + 1}. ${n.title}\\n   URL: ${n.url}\\n   날짜: ${n.pubDate}`\n).join('\\n\\n');\n\nreturn [{ json: { newsText } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
